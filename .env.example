# FootyStats / football-data-api API key
# Used by: fetch_data.py, today_matches.py, validate_main.py, validate_predictions.py
FOOTYSTATS_API_KEY=your-footystats-api-key

# Azure PostgreSQL password for user "winbets" (database: postgres)
# Used by: save_main.py, validate_main.py, validate_predictions.py
WINBETS_DB_PASSWORD=your-winbets-db-password

# Azure PostgreSQL password for user "app_user" (database: postgres)
# Used by: save.py
WINBETS_APP_USER_DB_PASSWORD=your-app-user-db-password
